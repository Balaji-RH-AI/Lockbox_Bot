AZURE_OPENAI_API_KEY="4TTGumsqn23IxbAMdXmzQylyA7Yb6eW6IBQjwupPgWTx8aHeWEqlJQQJ99BCACYeBjFXJ3w3AAABACOGEWP5"
AZURE_OPENAI_API_VERSION="2024-12-01-preview"
AZURE_DEPLOYMENT="gpt-4o-mini"
# Embeddings deployment for the in-app Help assistant (RAG over docs/). Create an
# embeddings deployment in Azure (e.g. text-embedding-3-small) and put its name here.
AZURE_EMBED_DEPLOYMENT="text-embedding-3-small"
# Optional: override the help docs folder (default ./docs)
# HELP_DOCS_DIR="docs"
SECRET_KEY="lockbox-bot-secret-2025"

# Optional: larger output budget for the /generator LLM conversion (default 16384)
# GENERATOR_MAX_TOKENS="16384"

# Google Drive (Submit → upload answers JSON to the user's Drive via OAuth)
# Enable the Google Drive API and create an OAuth 2.0 Client ID (type: Web application)
# at https://console.cloud.google.com/apis/credentials, then DOWNLOAD the client JSON
# and drop it in the project root (a file named client_secret*.json is auto-detected).
# Make sure the client's "Authorized redirect URIs" includes the redirect below.
#
# Optional: point at a specific credentials file (else client_secret*.json is auto-found):
# GOOGLE_CREDENTIALS_FILE="client_secret.json"
# Optional: override the redirect URI (else the first one in the JSON is used):
# GOOGLE_REDIRECT_URI="http://localhost:5000/auth/google/callback"
# Optional: upload into a specific folder (the folder's ID from its Drive URL). Blank = Drive root.
GOOGLE_DRIVE_FOLDER_ID=""